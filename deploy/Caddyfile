# Caddy handles TLS (ACME) and reverse-proxies the signaling WebSocket and the
# embedded SPA to conduit-server. conduit-server only issues TURN credentials;
# the actual TURN media path goes directly between clients and the configured
# TURN provider (e.g. turn.cloudflare.com), not through this Caddy.
#
# Replace conduit.example.com with your hostname.

conduit.example.com {
	encode zstd gzip

	@ws path /ws
	handle @ws {
		reverse_proxy http://127.0.0.1:8080
	}

	handle /healthz {
		reverse_proxy http://127.0.0.1:8080
	}

	handle {
		reverse_proxy http://127.0.0.1:8080
	}

	log {
		output file /var/log/caddy/conduit.log
	}
}
